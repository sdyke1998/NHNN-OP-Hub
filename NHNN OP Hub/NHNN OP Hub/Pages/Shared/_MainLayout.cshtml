<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NHNN_OP_Hub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NHNN OP Hub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
       
    </header>

    <nav>
        <div class="app-title">
            <p>NHNN Outpatients Hub</p>
        </div>

        <ul>
            <li>
                <a class="nav-link" href="">
                    <p class="link-title">Posting</p>
                    <span class="nav-noti">0</span>
                </a>
            </li>
            <li>
                <a class="nav-link" href="">
                    <p class="link-title">Outpatients</p>
                    <span class="nav-noti">0</span>
                </a>
            </li>
        </ul>
    </nav>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
