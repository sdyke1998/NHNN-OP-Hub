@page
@model NHNN_OP_Hub.Pages.PostingModel
@{
    Layout = "~/Pages/Shared/_MainLayout.cshtml";
}

<h1 class="main-title">Posting</h1>

<div class="main-body">

    <div class="search-db">
        <form id="search-form" method="POST" asp-page-handler="Search">

            <div class="search-group">
                <label for="byName">Search by name</label>
                <input type="text" id="byName" asp-for="ByName" />
            </div>

            <div class="search-group">
                <label for="byMRN">Search by MRN</label>
                <input type="text" id="byMRN" asp-for="ByMRN" />
            </div>

            <div class="search-group">
                <label for="byDate">Search by Date</label>
                <input type="date" id="byDate" asp-for="ByDate" value="" />
            </div>

            <div class="search-group">
                <label for="reset">Clear</label>
                <input type="reset" id="reset" />
            </div>

            <button type="submit" id="searchButton">Search</button>
        </form>
        <p style="color:red">@Model.SearchPatientErrorMessage</p>
    </div>

    <div class="pt-table">
        <table>
            <thead>
                <tr>
                    <th>Work request ID</th>
                    <th>Name</th>
                    <th>MRN</th>
                    <th>Date dispensed</th>
                    <th>Is paying?</th>
                    <th>Is private?</th>
                    <th>Prescription cost</th>
                    <th>Receipt number</th>
                    <th>Delivery Address</th>
                    <th>Tracking number</th>
                    <th>Has been returned?</th>
                </tr>
            </thead>
            <tbody>
                @{
                    @foreach (var pt in Model.PackagesToDisplay)
                    {
                        <tr class="pt-data-row" onclick="window.location.href='/ViewRecord/@pt.WorkRequestID'">
                            <td>@pt.WorkRequestID</td>
                            <td>@pt.Name</td>
                            <td>@pt.MRN</td>
                            <td>@pt.DateDispensed.ToString("g")</td>
                            <td>@pt.IsPaying</td>
                            <td>@pt.IsPrivate</td>
                            <td>@pt.RxCost</td>
                            <td>@pt.ReciptNumber</td>
                            <td>@pt.DeliveryAddress</td>
                            <td>@pt.TrackingNumber</td>
                            <td>@pt.HasReturned</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <h3 class="add-op-title">Add a posting package below</h3>

    <div class="pt-entry-form">
        <form id="pt-entry" method="POST" asp-page-handler="Enter">

            <div class="form-group">
                <label for="ptName">Patient Name</label>
                <input type="text" id="ptName" asp-for="ptName" required />
            </div>

            <div class="form-group">
                <label for="MRN">MRN</label>
                <input type="text" id="MRN" asp-for="MRN" required />
            </div>

            <div class="form-group">
                <label for="deliveryAddress">Delivery Address</label>
                <input type="text" id="deliveryAddress" asp-for="deliveryAddress" required />
            </div>

            <div class="form-group">
                <label for="trackingNum">Tracking Number</label>
                <input type="text" id="trackingNum" asp-for="trackingNum" />
            </div>

            <div class="form-group">
                <label for="isPaying">Is paying</label>
                <input type="checkbox" id="isPaying" asp-for="isPaying" />
            </div>

            <div class="form-group">
                <label for="isPrivate">Private prescription</label>
                <input type="checkbox" id="isPrivate" asp-for="isPrivate" />
            </div>

            <div class="form-group">
                <label for="rxCost">Prescription Cost</label>
                <input type="number" step="0.01" id="rxCost" asp-for="rxCost" min="0" />
            </div>

            <div class="form-group">
                <label for="reciptNum">Receipt Number</label>
                <input type="number" id="reciptNum" asp-for="reciptNum" min="1000" />
            </div>

            <div class="form-group">
                <label for="hasReturned">Prescription returned?</label>
                <input type="checkbox" id="hasReturned" asp-for="hasReturned" />
            </div>

            <div class="form-reset">
                <label for="reset">Reset</label>
                <input type="reset" id="reset" />
            </div>

            <button type="submit" id="loginButton">Enter</button>
        </form>

        <p style="color:red">@Model.AddPatientErrorMessage</p>
    </div>
</div>